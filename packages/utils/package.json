{
  "name": "@budgetbuddyde/utils",
  "version": "1.3.4",
  "private": true,
  "description": "This package provides some utility functions that are frequently used in this project.",
  "keywords": [
    "utility",
    "helper",
    "functions"
  ],
  "author": "Thorben",
  "license": "MIT",
  "homepage": "https://github.com/BudgetBuddyDE/BudgetBuddyDE",
  "repository": {
    "type": "git",
    "url": "https://github.com/BudgetBuddyDE/BudgetBuddyDE.git"
  },
  "bugs": {
    "url": "https://github.com/BudgetBuddyDE/BudgetBuddyDE/issues"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "rimraf lib && tsc",
    "pretest": "npm run check",
    "test": "vitest run --silent",
    "test:watch": "vitest",
    "check": "npm run format:check && npm run lint:check",
    "check:write": "npm run lint && npm run format",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --max-warnings=0",
    "lint:check": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "peerDependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/ui": "^3.0.9",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
