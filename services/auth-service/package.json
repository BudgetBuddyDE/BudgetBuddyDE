{
  "name": "@budgetbuddyde/auth-service",
  "version": "0.0.5",
  "private": true,
  "main": "build/src/server.js",
  "scripts": {
    "start": "node build/src/server.js",
    "start:instrumentation": "node --import ./build/instrumentation.js build/src/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:instrumentation": "tsx watch --import ./instrumentation.ts ./src/server.ts",
    "build": "npx rimraf build && npx tsc",
    "pretest": "npm run check",
    "test": "vitest run",
    "check": "npm run format:check && npm run lint:check",
    "check:write": "npm run lint && npm run format",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" instrumentation.ts --fix --max-warnings=0",
    "lint:check": "eslint \"src/**/*.{js,jsx,ts,tsx}\" instrumentation.ts --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\" instrumentation.ts",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\" instrumentation.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/budgetbuddyde/budgetbuddyde.git"
  },
  "author": "Thorben Klein",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/budgetbuddyde/budgetbuddyde/issues"
  },
  "homepage": "https://github.com/budgetbuddyde/budgetbuddyde#readme",
  "description": "",
  "dependencies": {
    "@budgetbuddyde/db": "workspace:*",
    "@budgetbuddyde/logger": "workspace:*",
    "@budgetbuddyde/types": "workspace:*",
    "@budgetbuddyde/utils": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.3",
    "@opentelemetry/exporter-prometheus": "^0.208.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "better-auth": "1.2.9",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.2",
    "ioredis": "^5.8.2",
    "node-cron": "^4.2.0",
    "pg": "^8.16.1",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.1.2",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/pg": "^8.15.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
