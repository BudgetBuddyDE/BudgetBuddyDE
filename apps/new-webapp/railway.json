{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npx turbo run build --filter=@budgetbuddyde/new-webapp",
    "watchPatterns": ["/apps/new-webapp/**", "/packages/**"],
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "npx turbo run start --filter=@budgetbuddyde/new-webapp",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 15,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 1
  }
}
