{
  "name": "@budgetbuddyde/backend",
  "version": "0.5.1",
  "main": "build/src/server.js",
  "scripts": {
    "start": "node build/src/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "npx rimraf build && npx tsc",
    "pretest": "npm run check",
    "test": "vitest run",
    "check": "npm run format:check && npm run lint:check",
    "check:write": "npm run lint && npm run format",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --max-warnings=0",
    "lint:check": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/budgetbuddyde/budgetbuddyde.git"
  },
  "author": "Thorben Klein",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/budgetbuddyde/budgetbuddyde/issues"
  },
  "homepage": "https://github.com/budgetbuddyde/budgetbuddyde#readme",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@better-auth/api-key": "^1.5.6",
    "@budgetbuddyde/api": "*",
    "@budgetbuddyde/db": "*",
    "@budgetbuddyde/logger": "0.1.1",
    "@budgetbuddyde/types": "*",
    "@budgetbuddyde/utils": "1.3.4",
    "better-auth": "^1.5.6",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.2",
    "express-zod-safe": "^3.1.0",
    "ioredis": "^5.8.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.16.1",
    "rate-limit-redis": "^4.3.1",
    "uuidv7": "^1.1.0",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.3",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
