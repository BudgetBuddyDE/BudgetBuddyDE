    "budgetbuddy_backend.spending_goal_view": {
      "columns": {
        "budget_id": {
          "name": "budget_id",
          "type": "uuid",
          "primaryKey": false,
          "notNull": true
        },
        "owner_id": {
          "name": "owner_id",
