{
  "name": "budgetbuddyde",
  "private": true,
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/webapp"
  ],
  "scripts": {
    "prepare": "node .husky/install.mjs",
    "dev": "turbo run dev",
    "dev-services": "turbo run dev --filter=./services/*",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "lint": "turbo run lint && eslint vitest.config.ts --fix --max-warnings=0",
    "lint:check": "turbo run lint:check && eslint vitest.config.ts --max-warnings=0",
    "check": "turbo run check",
    "check:write": "turbo run check:write",
    "test": "turbo run test",
    "build": "turbo run build",
    "build-packages": "turbo run build --filter=./packages/*",
    "build-services": "turbo run build --filter=./services/*",
    "build-apps": "turbo run build --filter=./apps/*",
    "typecheck": "turbo run typecheck",
    "ci": "npm run format:check && npm run lint:check && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "turbo": "^2.9.14",
    "typescript-eslint": "^8.61.0"
  }
}